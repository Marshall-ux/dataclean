# Copiá este archivo como .env y completá los valores antes de correr en producción.
# El archivo .env NUNCA debe subirse al repositorio (agregalo a .gitignore).

# Clave secreta para Flask (generá una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# Orígenes permitidos para CORS (separá múltiples con coma, sin espacios)
# Ejemplo producción: CORS_ORIGINS=https://mi-sitio.com,https://www.mi-sitio.com
# Ejemplo desarrollo: CORS_ORIGINS=http://localhost:5001
CORS_ORIGINS=*

# Activar modo debug de Flask (solo en desarrollo — nunca en producción)
FLASK_DEBUG=false

# Puerto del servidor
PORT=5001
